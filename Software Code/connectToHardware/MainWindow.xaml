<Window x:Class="PicoSerialWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PicoSerialWpf"
        Title="Pico Serial Control" Height="450" Width="800">


<!-- the view implement the observer pattern, the binding acts as the observer --> 
<!-- essentially the The View observes the ViewModel through the binding system-->
<!-- the binding acts as the Concrete Observer-->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*"/>
            <ColumnDefinition Width="0.5*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="{Binding ErrorMessage}" />
        <TextBlock Text="{Binding RealStatus}" Grid.Column="1"/>

        <Button Content="ON"
                    Width="50"
                    Height="30"
                    Margin="0,0,8,0"
               
                    Command="{Binding OnCommand}"
                        
                    Grid.Column="0"/>

        <Button Content="OFF"
                    Width="50"
                    Height="30"
                    Margin="0,0,8,0"
               
                    Command="{Binding OffCommand}"
                    Grid.Column="1"/>
    </Grid>
</Window>
